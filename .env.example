# Configuración de Supabase
# Copia este archivo como .env y completa los valores

# URL de tu proyecto Supabase (ejemplo: https://xxxxx.supabase.co)
EXPO_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave pública (anon key) de tu proyecto Supabase
# La encuentras en: Supabase Dashboard > Settings > API > Project API keys
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui